{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Generate Dev Build",
      "type": "process",
      "command": "dotnet",
      "args": [
        "publish",
        "-c", "Debug",
        "-r", "win-x64",
        "--self-contained", "true",
        "-p:PublishSingleFile=true",
        "-o", "${workspaceFolder}/dev"
      ],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Generate Release",
      "type": "process",
      "command": "dotnet",
      "args": [
        "publish",
        "-c", "Release",
        "-r", "win-x64",
        "--self-contained", "true",
        "-p:PublishSingleFile=true",
        "-o", "${workspaceFolder}/publish"
      ],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": "$msCompile"
    }
  ]
}
